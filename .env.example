# Variáveis de ambiente — copiar para .env (local) e definir na Vercel (prod).

# Neon Postgres (connection string com sslmode=require)
DATABASE_URL=

# Web Push (VAPID). Gerar com: pnpm exec web-push generate-vapid-keys
# A pública é a mesma nas duas primeiras; NEXT_PUBLIC_ é exposta ao browser.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Segredo partilhado entre o cron externo (cron-job.org / GitHub Actions) e
# /api/cron/check-reminders
CRON_SECRET=

# Inngest (agendador dos lembretes). Do dashboard do Inngest; a integração
# Inngest↔Vercel também define estas na Vercel automaticamente.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
